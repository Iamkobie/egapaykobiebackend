# ─── eGov SSO Partner Credentials ───────────────────────────────────────────
EGOV_BASE_URL=https://staging-sso.oueg.info
EGOV_PARTNER_CODE=your_partner_code_here
EGOV_PARTNER_SECRET=your_partner_secret_here

# ─── Our App JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/egov_sso_app

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── Frontend (used for SSO redirect after callback) ──────────────────────────
# eGov redirects to GET /api/auth/sso/callback, then we redirect here with the token
FRONTEND_URL=http://localhost:5173
